# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public booking (PrimeCraft). Omit to use default Mari workspace URL.
NEXT_PUBLIC_BOOKING_URL=https://primecraft.mothership-ai.com/p/mbbtattoos

# xAI (Grok chat + TTS)
XAI_API_KEY=

# Square — use sandbox first; placeholders skip live payments
SQUARE_APPLICATION_ID=placeholder
SQUARE_ACCESS_TOKEN=placeholder
SQUARE_LOCATION_ID=placeholder
SQUARE_WEBHOOK_SIGNATURE_KEY=placeholder
NEXT_PUBLIC_SQUARE_APPLICATION_ID=placeholder
NEXT_PUBLIC_SQUARE_LOCATION_ID=placeholder

# Neon Postgres
DATABASE_URL=

# Vercel Blob (reference uploads)
BLOB_READ_WRITE_TOKEN=

# Resend
RESEND_API_KEY=

# Sanity — portfolio (hosted Studio: https://www.sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=
SANITY_REVALIDATE_SECRET=

# Instagram Graph API (optional; no longer used for portfolio — kept for future use)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Upstash (optional — in-memory fallback when unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron routes (Vercel sends Authorization: Bearer)
CRON_SECRET=

# Admin (/admin) — password to log in; optional stronger signing secret
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
